# ============================================================
# Pulse — Expense Manager  |  Environment Variables Template
# ============================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# ============================================================

# ── Database ─────────────────────────────────────────────
# PostgreSQL connection string.
# Local:    postgresql://postgres:password@localhost:5432/pulse
# Neon:     postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/pulse?sslmode=require
# Supabase: postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/pulse

# PostgreSQL individual components (used by some tools/Replit)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=password
PGDATABASE=pulse

# ── Clerk Authentication ──────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
#
# Secret key (backend only — never expose to the browser)
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# Publishable key (safe for browser)
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Vite exposes env vars to the browser only when prefixed with VITE_
# Set this to the same value as CLERK_PUBLISHABLE_KEY
VITE_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# ── Clerk Proxy (production only) ────────────────────────
# Only set this when deploying to a domain that doesn't have
# a Clerk CNAME record (e.g. *.replit.app, *.railway.app).
# The API server proxies Clerk's FAPI & npm CDN through /api/__clerk.
# Leave blank in local development.
#
# VITE_CLERK_PROXY_URL=https://your-domain.com/api/__clerk

# ── Session ──────────────────────────────────────────────
# Random secret used to sign session cookies.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=REPLACE_WITH_RANDOM_32_CHAR_STRING

# ── Server ───────────────────────────────────────────────
# Port the API server listens on.
# Replit sets this automatically. For local dev it defaults to 8080.
PORT=8080

# Node environment — set to "production" in deployed environments.
# NODE_ENV=production
